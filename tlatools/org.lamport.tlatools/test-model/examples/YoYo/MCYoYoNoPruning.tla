          {5,11}, {5,12}, {5,20}, {7,20}, {7,31}, 
          {11,12}, {12,20}, {20,41}}
*)

VARIABLES phase, incoming, outgoing, mailbox

INSTANCE YoYoNoPruning

AllPermanentlyDown == <>[](\A n \in Nodes : phase[n] = "down")

