--------------------------- MODULE MCYoYoNoPruning ---------------------------
EXTENDS Integers, TLC, TLCExt

Nodes == 1 .. 5
Edges == {{1,2}, {1,5}, {3,4}, {3,5}, {4,5}}

(*
Nodes == {2,3,4,5,7,11,12,14,20,31,41}
